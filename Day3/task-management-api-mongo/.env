NODE_ENV=development
PORT=3001

# Atlas (db name: 5day)
# NOTE: '@' in password must be URL-encoded as '%40'

MONGODB_URI=mongodb+srv://test:Test@testcluster.mongodb.net/test?retryWrites=true&w=majority&appName=testcluster
MONGODB_MIN_POOL_SIZE=2
MONGODB_MAX_POOL_SIZE=10

REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600

CORS_ORIGIN=http://localhost:3000

